{
  "name": "spiki",
  "version": "0.1.0-dev",
  "description": "Editor-oriented MCP reference implementation for stable agent workspace operations",
  "license": "MIT",
  "author": "seo-rii",
  "type": "module",
  "homepage": "https://github.com/seo-rii/spiki#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seo-rii/spiki.git"
  },
  "bugs": {
    "url": "https://github.com/seo-rii/spiki/issues"
  },
  "keywords": [
    "agent",
    "editor",
    "mcp",
    "model-context-protocol",
    "node",
    "rust"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "launcher/",
    "scripts/",
    "crates/",
    "docs/",
    "Cargo.toml",
    "Cargo.lock",
    "README.md",
    "SPEC.md",
    "LICENSE"
  ],
  "bin": {
    "spiki": "./bin/spiki.js"
  },
  "scripts": {
    "build:daemon": "node ./scripts/build-daemon.mjs",
    "test:smoke": "node --test ./tests/program-exec.test.mjs",
    "test:codex": "node --test ./tests/codex-integration.test.mjs",
    "test:integration": "node --test ./tests/*.test.mjs"
  }
}
